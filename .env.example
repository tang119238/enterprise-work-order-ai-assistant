LLM_PROVIDER=offline
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_FALLBACK_ENABLED=true
WORK_ORDER_BASE_URL=http://127.0.0.1:8080
KNOWLEDGE_PATH=knowledge/policies

# Local Compose database identities. Development-only values; replace outside local demos.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_dev
FLYWAY_PASSWORD=flyway_owner_dev
WORK_ORDER_DB_PASSWORD=work_order_app_dev
AI_DB_PASSWORD=ai_app_dev
ANALYTICS_DB_PASSWORD=analytics_reader_dev

# JWT verification. The issuer must sign RS256 tokens whose public key is configured here.
# Keep the signing/private key in the issuer or a secret store; never put it in this repository.
JWT_ISSUER_URI=http://localhost:9000
JWT_AUDIENCE=work-order-service
JWT_JWK_SET_URI=
JWT_PUBLIC_KEY_LOCATION=classpath:security/dev-jwt-public-key.pem

# Authenticated live smoke prerequisites. Use short-lived synthetic-only test JWTs.
# The database must contain matching ACTIVE identities, memberships, and project scopes.
SMOKE_JWT_ISSUER=http://localhost:9000
SMOKE_JWT_AUDIENCE=work-order-service
SMOKE_DISPATCHER_TOKEN=
SMOKE_TENANT_B_TOKEN=
SMOKE_AI_TOKEN=
SMOKE_WAIT_SECONDS=180
SMOKE_REQUEST_TIMEOUT_SECONDS=5
SMOKE_COMPOSE_FILE=docker-compose.yml
SMOKE_TENANT_A_ID=11111111-1111-1111-1111-111111111111
SMOKE_TENANT_B_ID=22222222-2222-2222-2222-222222222222
SMOKE_TENANT_A_PROJECT_ID=00000000-0000-0000-0000-000000010001
SMOKE_TENANT_B_PROJECT_ID=00000000-0000-0000-0000-000000020001
