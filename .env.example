LLM_PROVIDER=offline
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_FALLBACK_ENABLED=true
WORK_ORDER_BASE_URL=http://127.0.0.1:8080
KNOWLEDGE_PATH=knowledge/policies

# Local Compose role-bootstrap identities. Development-only values; replace outside local demos.
# These raw passwords initialize PostgreSQL roles; do not splice them into database URLs.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_dev
FLYWAY_PASSWORD=flyway_owner_dev
WORK_ORDER_DB_PASSWORD=work_order_app_dev
AI_DB_PASSWORD=ai_app_dev
ANALYTICS_DB_PASSWORD=analytics_reader_dev

# Container-network URLs for local Compose. Runtime repositories use ai_app; only an explicit
# one-shot Alembic command may consume the migration-owner URL after migrations are added.
# Supply each URL as one canonical value and percent-encode URI-reserved password characters.
AI_DATABASE_URL=postgresql+asyncpg://ai_app:ai_app_dev@postgres:5432/workorders
AI_MIGRATION_DATABASE_URL=postgresql+asyncpg://flyway_owner:flyway_owner_dev@postgres:5432/workorders
PGVECTOR_ADMIN_DATABASE_URL=postgresql+asyncpg://postgres:postgres_dev@postgres:5432/workorders

# Base Compose intentionally exposes no host database port. For host-run Python or Alembic,
# first provide a separately reachable pgvector database (or an explicit personal port override),
# then set a host URL such as the following; percent-encode its password too:
# AI_DATABASE_URL=postgresql+asyncpg://ai_app:encoded-password@db.example.invalid:5432/workorders
# AI_MIGRATION_DATABASE_URL=postgresql+asyncpg://flyway_owner:encoded-password@db.example.invalid:5432/workorders
# PGVECTOR_ADMIN_DATABASE_URL=postgresql+asyncpg://postgres:encoded-password@db.example.invalid:5432/workorders

# Local 512-dimension embeddings. The named Compose volume supplies this cache at runtime;
# model weights are downloaded on first use and are never baked into the image or committed.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSIONS=512
FASTEMBED_CACHE_PATH=/models

# JWT verification. The issuer must sign RS256 tokens whose public key is configured here.
# Keep the signing/private key in the issuer or a secret store; never put it in this repository.
JWT_ISSUER_URI=http://localhost:9000
JWT_AUDIENCE=work-order-service
JWT_JWK_SET_URI=
JWT_PUBLIC_KEY_LOCATION=classpath:security/dev-jwt-public-key.pem

# Authenticated live smoke defaults. Prefer scripts/generate_smoke_fixtures.py --output .smoke;
# it writes short-lived synthetic tokens and idempotent authorization SQL to ignored files.
SMOKE_JWT_ISSUER=http://localhost:9000
SMOKE_JWT_AUDIENCE=work-order-service
SMOKE_JWT_PUBLIC_KEY_PATH=.smoke/jwt-public.pem
SMOKE_DISPATCHER_TOKEN=
SMOKE_TENANT_B_TOKEN=
SMOKE_AI_TOKEN=
SMOKE_RUNTIME_DB_USER=work_order_app
SMOKE_RUNTIME_DB_PASSWORD=work_order_app_dev
SMOKE_PROVISION_SQL=.smoke/provision.sql
SMOKE_WAIT_SECONDS=180
SMOKE_REQUEST_TIMEOUT_SECONDS=5
SMOKE_COMPOSE_FILE=docker-compose.yml
SMOKE_TENANT_A_ID=11111111-1111-1111-1111-111111111111
SMOKE_TENANT_B_ID=22222222-2222-2222-2222-222222222222
SMOKE_TENANT_A_PROJECT_ID=00000000-0000-0000-0000-000000010001
SMOKE_TENANT_B_PROJECT_ID=00000000-0000-0000-0000-000000020001
